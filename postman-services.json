        "from": "salesforce-revenue-onboarding-api",
        "to": "workday-workforce-provisioning-api",
        "relationship": "close-won triggers customer-side workforce provisioning"
      },
      {
        "from": "workday-workforce-provisioning-api",
        "to": "salesforce-revenue-onboarding-api",
        "relationship": "requests Salesforce access for provisioned workers"
      },
      {
        "from": "qa-automation-control-plane-api",
        "to": "oracle-order-orchestration-api",
        "relationship": "runs integration test suites against order orchestration"
      },
      {
        "from": "qa-automation-control-plane-api",
        "to": "salesforce-revenue-onboarding-api",
        "relationship": "runs regression suites against revenue onboarding"
      },
      {
        "from": "qa-automation-control-plane-api",
        "to": "workday-workforce-provisioning-api",
        "relationship": "runs provisioning validation suites"
      },
      {
        "from": "qa-automation-control-plane-api",
        "to": "payments-api",
        "relationship": "runs payment smoke and contract suites"
      },
      {
        "from": "qa-automation-control-plane-api",
        "to": "accounts-api",
        "relationship": "runs account smoke and contract suites"
      }
    ]
  },
